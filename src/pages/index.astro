---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkInput from '../components/LinkInput.astro';
---

<BaseLayout title="GrabTube — Download YouTube videos & MP3s, fast">
  <section class="hero">
    <p class="eyebrow">No apps · No accounts · No clutter</p>
    <h1>Grab any YouTube <span class="grad">video</span> or <span class="grad">playlist</span>.</h1>
    <p class="lede">
      Paste a link below. Download it as crisp MP4 up to 1080p, or pull clean MP3 audio with the
      cover art, title, and author baked right in.
    </p>
    <LinkInput autofocus={true} />
    <p class="hint muted">Try a single video or a full playlist link.</p>
  </section>

  <section class="features">
    <div class="feature card">
      <h2>🎬 Video, your way</h2>
      <p class="muted">Pick from the qualities each video actually offers, up to Full HD 1080p.</p>
    </div>
    <div class="feature card">
      <h2>🎵 Rich MP3s</h2>
      <p class="muted">Audio downloads carry the title, author, and thumbnail as embedded metadata.</p>
    </div>
    <div class="feature card">
      <h2>📦 Whole playlists</h2>
      <p class="muted">Drop a playlist link and get every video bundled into a single ZIP.</p>
    </div>
  </section>
</BaseLayout>

<script>
  // Enhancement: remember the link so the download page can read it even without query params.
  const form = document.querySelector('[data-link-form]') as HTMLFormElement | null;
  form?.addEventListener('submit', () => {
    const input = form.querySelector('input[name="url"]') as HTMLInputElement | null;
    try {
      if (input?.value) sessionStorage.setItem('yt-url', input.value);
    } catch {
      /* ignore storage errors */
    }
  });
</script>

<style>
  .hero {
    text-align: center;
    max-width: 60ch;
    margin-inline: auto;
    margin-bottom: var(--sp-16);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: var(--fs-300);
    color: var(--c-accent-2);
    margin-bottom: var(--sp-4);
  }
  .grad {
    background: var(--c-accent-grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    color: var(--c-text-dim);
    font-size: var(--fs-400);
    margin-block: var(--sp-4) var(--sp-8);
  }
  .hint {
    font-size: var(--fs-300);
    margin-top: var(--sp-3);
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-4);
  }
  .feature h2 {
    font-size: var(--fs-400);
    margin-bottom: var(--sp-2);
  }
</style>
