---
// Format + quality selection (FR-005, FR-006, FR-007) and the MP3 metadata confirmation
// panel (FR-008). Static shell; the island toggles visibility and fills the quality list.
---
<section id="formats" class="card" hidden>
  <h2>Choose your download</h2>

  <div class="format-toggle" role="radiogroup" aria-label="Download format">
    <label class="opt">
      <input type="radio" name="format" value="mp4" checked />
      <span>🎬 Video · MP4</span>
    </label>
    <label class="opt">
      <input type="radio" name="format" value="mp3" />
      <span>🎵 Audio · MP3</span>
    </label>
  </div>

  <div id="quality-row" class="quality-row">
    <label for="quality">Quality</label>
    <select id="quality" name="quality"></select>
    <span class="muted small">Up to 1080p</span>
  </div>

  <div id="mp3-meta" class="mp3-meta" hidden>
    <p class="muted small">Your MP3 will include this metadata:</p>
    <ul class="meta-list">
      <li>Title: <span id="meta-title">—</span></li>
      <li>Author: <span id="meta-author">—</span></li>
      <li>Cover art: <span id="meta-cover">—</span></li>
    </ul>
  </div>

  <button id="start-btn" class="btn btn-primary" type="button">Download</button>
</section>

<style>
  .format-toggle {
    display: flex;
    gap: var(--sp-3);
    margin-block: var(--sp-4);
    flex-wrap: wrap;
  }
  .opt {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    cursor: pointer;
  }
  .opt:has(input:checked) {
    border-color: var(--c-accent);
    box-shadow: inset 0 0 0 1px var(--c-accent);
  }
  .quality-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
    flex-wrap: wrap;
  }
  select {
    font: inherit;
    color: var(--c-text);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    padding: var(--sp-2) var(--sp-3);
  }
  .meta-list {
    margin: var(--sp-2) 0 var(--sp-4);
    padding-left: 1.25rem;
  }
  .small {
    font-size: var(--fs-300);
  }
</style>
